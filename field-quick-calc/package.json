{
  "name": "field-quick-calc",
  "version": "0.1.0",
  "description": "DIY-focused imperial jobsite calculator prototype",
  "main": "index.js",
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "start": "npm run build && python3 -m http.server 3004 -d dist",
